# Copy this file to .env and fill in real values.
# NEVER commit the real .env file to git.

PORT=5000

# Razorpay (get from https://dashboard.razorpay.com/app/keys)
# ROTATE any key that was ever committed or shared before pasting a new one here.
RAZORPAY_KEY_ID=rzp_live_or_test_key_id
RAZORPAY_KEY_SECRET=your_secret_key_here

# MongoDB
# Local:  mongodb://localhost:27017
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=gowtham_mess

# Admin dashboard login (Basic Auth) — used at /admin
ADMIN_USER=admin
ADMIN_PASS=change_this_password

# JWT secret for customer login sessions — use a long random string, keep it secret
JWT_SECRET=change_this_to_a_long_random_string
